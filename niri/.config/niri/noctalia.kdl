layout {

    focus-ring {
        active-color   "#ecc248"
        inactive-color "#15130e"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ecc248"
        inactive-color "#15130e"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ecc248"
        inactive-color "#584400"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ecc24880"
    }
}

recent-windows {
    highlight {
        active-color "#ecc248"
        urgent-color "#ffb4ab"
    }
}
